# Neon Postgres connection string
# https://console.neon.tech/ → 프로젝트 만들기 → Connection string 복사
# 형식: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# 익명성 보호용 서버 비밀키 (랜덤 긴 문자열, 16자 이상)
# 예) openssl rand -hex 32
SERVER_SECRET=replace-me-with-long-random-string

# /admin 페이지 비밀번호 (운영자 본인만 사용)
ADMIN_PASSWORD=change-me

# 사이트 시작일 (D+1 = 이 날짜). KST 기준 YYYY-MM-DD.
SITE_LAUNCH_DATE=2026-05-19

# 배포 URL. OG 메타 + admin 로그아웃 리다이렉트에 사용.
# 예: https://wearestar-git-main-p2p-js-projects.vercel.app
NEXT_PUBLIC_SITE_URL=
