# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 익명성 보호용 서버 비밀키 (랜덤 긴 문자열)
SERVER_SECRET=replace-me-with-long-random-string

# /admin 페이지 비밀번호 (1명만 사용)
ADMIN_PASSWORD=change-me

# 사이트 시작일 (D+1 = 이 날짜). KST 기준 YYYY-MM-DD.
SITE_LAUNCH_DATE=2026-04-02

# 배포 URL (선택). OG 메타 + admin 로그아웃 리다이렉트에 사용.
# 예: https://wearestar.example
NEXT_PUBLIC_SITE_URL=
